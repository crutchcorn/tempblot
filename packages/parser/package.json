{
  "name": "@tempblot/parser",
  "version": "0.2.0",
  "type": "module",
  "description": "Shared parser utilities for Tempblot",
  "author": "Corbin Crutchley <crutchcorn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crutchcorn/tempblot.git",
    "directory": "packages/parser"
  },
  "homepage": "https://github.com/crutchcorn/tempblot",
  "bugs": {
    "url": "https://github.com/crutchcorn/tempblot/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/crutchcorn"
  },
  "keywords": [
    "parser",
    "tempblot",
    "template",
    "templating",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepack": "tsc --build tsconfig.build.json --clean && tsc --build tsconfig.build.json",
    "test:lib": "vitest",
    "test:types": "tsc --noEmit --project tsconfig.spec.json",
    "test:eslint": "eslint ."
  },
  "devDependencies": {
    "@tempblot/config": "workspace:*",
    "@types/node": "^24.5.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "sideEffects": false
}
