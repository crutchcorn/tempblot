{
  "name": "@tempblot/typescript-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "A TypeScript plugin to support language features in Tempblot files",
  "author": "Corbin Crutchley <crutchcorn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crutchcorn/tempblot.git",
    "directory": "packages/typescript-plugin"
  },
  "homepage": "https://github.com/crutchcorn/tempblot",
  "bugs": {
    "url": "https://github.com/crutchcorn/tempblot/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/crutchcorn"
  },
  "main": "./lib/index.cjs",
  "exports": {
    "types": "./types/index.d.cts",
    "default": "./lib/index.cjs"
  },
  "files": [
    "lib",
    "types"
  ],
  "keywords": [
    "intellisense",
    "language-service",
    "tempblot",
    "templating",
    "typescript",
    "typescript-plugin"
  ],
  "scripts": {
    "prepack": "tsc --build --clean && tsc --build",
    "build": "tsc --build",
    "test:eslint": "eslint ."
  },
  "dependencies": {
    "@tempblot/language-service": "^0.1.0",
    "@volar/typescript": "~2.4.23"
  },
  "devDependencies": {
    "@tempblot/config": "workspace:*",
    "@types/node": "^24.5.2",
    "typescript": "^6.0.3"
  },
  "sideEffects": false
}
