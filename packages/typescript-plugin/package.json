{
  "name": "@tempblot/typescript-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "A TypeScript plugin to support language features in Tempblot files",
  "main": "./lib/index.cjs",
  "exports": {
    "types": "./types/index.d.cts",
    "default": "./lib/index.cjs"
  },
  "files": [
    "lib",
    "types"
  ],
  "keywords": [
    "tempblot",
    "typescript",
    "plugin",
    "templating"
  ],
  "scripts": {
    "prepack": "tsc --build --clean && tsc --build",
    "build": "tsc --build",
    "test:eslint": "eslint ."
  },
  "dependencies": {
    "@tempblot/language-service": "workspace:*",
    "@volar/typescript": "~2.4.23"
  },
  "devDependencies": {
    "@tempblot/config": "workspace:*",
    "@types/node": "^24.5.2",
    "typescript": "^6.0.3"
  },
  "sideEffects": false
}
