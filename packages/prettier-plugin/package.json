{
  "name": "prettier-plugin-tempblot",
  "version": "0.0.1",
  "type": "module",
  "description": "Prettier plugin for Tempblot templates",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "prepack": "tsc --build tsconfig.build.json --clean && tsc --build tsconfig.build.json",
    "test:lib": "vitest",
    "test:eslint": "eslint ."
  },
  "dependencies": {
    "@tempblot/parser": "workspace:*"
  },
  "devDependencies": {
    "@tempblot/config": "workspace:*",
    "@types/node": "^24.5.2",
    "cli-testing-library": "^3.0.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "sideEffects": false
}
