{
  "name": "tempblot",
  "type": "module",
  "version": "0.0.1",
  "description": "A modern type-safe templating engine",
  "author": "crutchcorn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crutchcorn/tempblot.git",
    "directory": "packages/compiler"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/crutchcorn"
  },
  "scripts": {
    "build": "vite build",
    "test:lib": "vitest",
    "test:build": "publint && attw --profile esm-only --pack .",
    "test:types": "tsc --noEmit",
    "test:eslint": "eslint ."
  },
  "keywords": [],
  "dependencies": {
    "tempblot-parser": "workspace:*",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^24.5.2",
    "publint": "^0.3.21",
    "tempblot-config": "workspace:*",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
